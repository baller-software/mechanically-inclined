---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const formEndpoint = import.meta.env.PUBLIC_FORM_ENDPOINT || '';
---

<BaseLayout title="Contact" description="Get in touch with Mechanically Inclined Sprinkler Repair & More in Forney, TX. Call, email, or send us a message.">

  <!-- ===== PAGE HERO ===== -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1753012442320-b450d8b80b8b?w=1600&h=700&fit=crop&q=80"
        alt=""
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/80 to-slate-900/60"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary-light">Contact Us</p>
      <h1 class="mt-3 text-4xl font-bold text-white sm:text-5xl" style="line-height: 1.15;">
        Let's Get Your<br />Project Started
      </h1>
      <p class="mt-4 max-w-xl text-lg text-slate-300" style="line-height: 1.6;">
        Whether you need a quick repair or a complete overhaul, reach out and we'll get back to you promptly.
      </p>
    </div>
  </section>

  <!-- ===== CONTACT CARDS ===== -->
  <section class="relative -mt-10 z-10 mb-6">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-4 sm:grid-cols-3">
        <!-- Phone -->
        <a href="tel:9728007000" class="group flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-background)] p-5 shadow-lg transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-transform duration-200 group-hover:scale-110">
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)]">Phone</p>
            <p class="text-sm font-semibold text-[var(--color-text-primary)]">(972) 800-7000</p>
          </div>
        </a>

        <!-- Email -->
        <a href="mailto:jesse@iammechanicallyinclined.com" class="group flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-background)] p-5 shadow-lg transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-transform duration-200 group-hover:scale-110">
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)]">Email</p>
            <p class="text-sm font-semibold text-[var(--color-text-primary)] truncate">jesse@iammechanicallyinclined.com</p>
          </div>
        </a>

        <!-- Hours -->
        <div class="group flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-background)] p-5 shadow-lg">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-xs font-medium uppercase tracking-wider text-[var(--color-text-secondary)]">Hours</p>
            <p class="text-sm font-semibold text-[var(--color-text-primary)]">Mon-Sat: 8AM-8PM</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FORM + MAP/IMAGE ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Form -->
        <div>
          <h2 class="text-2xl font-bold text-[var(--color-text-primary)] sm:text-3xl">
            Send Us a Message
          </h2>
          <p class="mt-2 text-[var(--color-text-secondary)]">
            Fill out the form below and we'll get back to you as soon as possible.
          </p>
          <div class="mt-8">
            <ContactForm endpoint={formEndpoint} />
          </div>
        </div>

        <!-- Image / Location -->
        <div class="flex flex-col gap-6">
          <div class="overflow-hidden rounded-2xl flex-1">
            <img
              src="https://images.unsplash.com/photo-1713789296574-0e56ecd53cbb?w=700&h=500&fit=crop&q=80"
              alt="Beautiful brick home with well-maintained lawn"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              <div>
                <p class="font-semibold text-[var(--color-text-primary)]">309 Long Prairie Dr</p>
                <p class="text-sm text-[var(--color-text-secondary)]">Forney, TX</p>
                <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
                  Serving Forney, Rockwall, Heath, Mesquite, and the greater East Dallas area.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
