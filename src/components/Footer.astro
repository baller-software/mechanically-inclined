---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary text-white">
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
            </svg>
          </div>
          <div>
            <span class="text-base font-bold text-[var(--color-text-primary)]">Mechanically Inclined</span>
            <span class="block text-xs text-[var(--color-text-secondary)]">Sprinkler Repair & More</span>
          </div>
        </div>
        <p class="mt-4 text-sm text-[var(--color-text-secondary)]" style="line-height: 1.6;">
          Your resourceful water management partner in Forney, TX. Saving you money by saving water since day one.
        </p>
        <!-- Social -->
        <div class="mt-4 flex gap-3">
          <a href="https://www.facebook.com/mechanicallyinclinedtexas/" target="_blank" rel="noopener noreferrer" class="flex h-9 w-9 items-center justify-center rounded-lg bg-[var(--color-background)] text-[var(--color-text-secondary)] transition-all duration-200 hover:text-primary hover:shadow-sm" aria-label="Facebook">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://nextdoor.com/pages/mechanically-inclined-sprinkler-repair-more-forney-tx/" target="_blank" rel="noopener noreferrer" class="flex h-9 w-9 items-center justify-center rounded-lg bg-[var(--color-background)] text-[var(--color-text-secondary)] transition-all duration-200 hover:text-primary hover:shadow-sm" aria-label="Nextdoor">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm3.5 14.5h-2v-4c0-.828-.672-1.5-1.5-1.5s-1.5.672-1.5 1.5v4h-2v-4c0-1.933 1.567-3.5 3.5-3.5s3.5 1.567 3.5 3.5v4z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-primary)]">Quick Links</h3>
        <ul class="mt-4 space-y-2.5">
          <li><a href="/" class="text-sm text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-primary">Home</a></li>
          <li><a href="/about" class="text-sm text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-primary">About Us</a></li>
          <li><a href="/contact" class="text-sm text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-primary">Contact</a></li>
        </ul>
      </div>

      <!-- Contact details -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-primary)]">Contact</h3>
        <ul class="mt-4 space-y-2.5 text-sm text-[var(--color-text-secondary)]">
          <li>
            <a href="tel:9728007000" class="transition-colors duration-200 hover:text-primary">(972) 800-7000</a>
          </li>
          <li>
            <a href="mailto:jesse@iammechanicallyinclined.com" class="transition-colors duration-200 hover:text-primary break-all">jesse@iammechanicallyinclined.com</a>
          </li>
          <li>309 Long Prairie Dr, Forney, TX</li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-primary)]">Hours</h3>
        <ul class="mt-4 space-y-2.5 text-sm text-[var(--color-text-secondary)]">
          <li class="flex justify-between"><span>Mon &ndash; Sat</span><span>8 AM &ndash; 8 PM</span></li>
          <li class="flex justify-between"><span>Sunday</span><span>Closed</span></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-[var(--color-border)] pt-6 text-center text-sm text-[var(--color-text-disabled)]">
      &copy; {currentYear} Mechanically Inclined Sprinkler Repair & More. All rights reserved.
    </div>
  </div>
</footer>
