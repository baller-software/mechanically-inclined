---
// Chat widget markup — all logic is in the <script> tag below
---

<!-- Chat Bubble -->
<button
  id="chat-bubble"
  type="button"
  class="fixed bottom-5 right-5 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-primary text-white shadow-lg transition-all duration-200 hover:bg-primary-dark hover:scale-105 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
  aria-label="Open chat assistant"
  style="min-width: 44px; min-height: 44px;"
>
  <!-- Chat icon -->
  <svg id="chat-icon-open" class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
  </svg>
  <!-- Close icon -->
  <svg id="chat-icon-close" class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
  </svg>
</button>

<!-- Chat Panel -->
<div
  id="chat-panel"
  class="fixed bottom-24 right-5 z-50 hidden w-[calc(100vw-2.5rem)] max-w-sm origin-bottom-right scale-95 rounded-lg border border-[var(--color-border)] bg-[var(--color-background)] opacity-0 shadow-lg transition-all duration-200 sm:w-96"
  role="dialog"
  aria-label="Chat assistant"
>
  <!-- Header -->
  <div class="flex items-center justify-between rounded-t-lg bg-primary px-4 py-3">
    <div class="flex items-center gap-2">
      <div class="flex h-8 w-8 items-center justify-center rounded-full bg-white/20">
        <svg class="h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-semibold text-white">Chat Assistant</p>
        <p class="text-xs text-primary-light">Demo Bot</p>
      </div>
    </div>
    <button
      id="chat-close"
      type="button"
      class="rounded-md p-1 text-white/80 hover:text-white transition-colors"
      aria-label="Close chat"
      style="min-width: 44px; min-height: 44px; display: flex; align-items: center; justify-content: center;"
    >
      <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Demo banner -->
  <div class="border-b border-[var(--color-border)] bg-primary/5 px-4 py-2">
    <p class="text-xs text-[var(--color-text-secondary)]">
      This is a <strong>demo</strong> of what an AI assistant could do for your business website.
    </p>
  </div>

  <!-- Messages area -->
  <div id="chat-messages" class="h-72 overflow-y-auto px-4 py-3 space-y-3">
  </div>

  <!-- Input area -->
  <div class="border-t border-[var(--color-border)] p-3">
    <form id="chat-input-form" class="flex gap-2">
      <label for="chat-input" class="sr-only">Type a message</label>
      <input
        type="text"
        id="chat-input"
        class="flex-1 rounded-md border border-[var(--color-border)] bg-transparent px-3 py-2 text-sm text-[var(--color-text-primary)] placeholder:text-[var(--color-text-disabled)] focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary/20"
        placeholder="Type a message..."
        autocomplete="off"
        style="min-height: 40px;"
      />
      <button
        type="submit"
        class="rounded-md bg-primary px-3 py-2 text-white transition-colors hover:bg-primary-dark"
        aria-label="Send message"
        style="min-width: 44px; min-height: 40px;"
      >
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
      </button>
    </form>
  </div>
</div>

<script>
  import { INTRO_MESSAGE, CONVERSATION_TREE, KEYWORD_MAP, FALLBACK_MESSAGE } from '../data/chatbot-data.js';

  function initChatWidget() {
    const bubble = document.getElementById('chat-bubble')!;
    const panel = document.getElementById('chat-panel')!;
    const closeBtn = document.getElementById('chat-close')!;
    const iconOpen = document.getElementById('chat-icon-open')!;
    const iconClose = document.getElementById('chat-icon-close')!;
    const messagesArea = document.getElementById('chat-messages')!;
    const inputForm = document.getElementById('chat-input-form') as HTMLFormElement;
    const inputField = document.getElementById('chat-input') as HTMLInputElement;

    let isOpen = false;
    let initialized = false;

    function toggleChat() {
      isOpen = !isOpen;
      if (isOpen) {
        panel.classList.remove('hidden');
        // Trigger animation on next frame
        requestAnimationFrame(() => {
          panel.classList.remove('scale-95', 'opacity-0');
          panel.classList.add('scale-100', 'opacity-100');
        });
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
        bubble.setAttribute('aria-label', 'Close chat assistant');

        if (!initialized) {
          initialized = true;
          addBotMessage(INTRO_MESSAGE.text, INTRO_MESSAGE.quickReplies);
        }

        inputField.focus();
      } else {
        panel.classList.remove('scale-100', 'opacity-100');
        panel.classList.add('scale-95', 'opacity-0');
        setTimeout(() => panel.classList.add('hidden'), 200);
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        bubble.setAttribute('aria-label', 'Open chat assistant');
      }
    }

    function addBotMessage(text, quickReplies = []) {
      const wrapper = document.createElement('div');
      wrapper.className = 'flex flex-col items-start gap-2';

      const msgBubble = document.createElement('div');
      msgBubble.className = 'max-w-[85%] rounded-lg rounded-bl-none bg-[var(--color-surface)] px-3 py-2 text-sm text-[var(--color-text-primary)] whitespace-pre-line';
      msgBubble.textContent = text;
      wrapper.appendChild(msgBubble);

      if (quickReplies.length > 0) {
        const btnGroup = document.createElement('div');
        btnGroup.className = 'flex flex-wrap gap-1.5 mt-1';
        quickReplies.forEach(reply => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'rounded-full border border-primary/30 bg-primary/5 px-3 py-1.5 text-xs font-medium text-primary transition-colors hover:bg-primary/10';
          btn.textContent = reply.label;
          btn.addEventListener('click', () => handleAction(reply.action));
          btnGroup.appendChild(btn);
        });
        wrapper.appendChild(btnGroup);
      }

      messagesArea.appendChild(wrapper);
      messagesArea.scrollTop = messagesArea.scrollHeight;
    }

    function addUserMessage(text) {
      const wrapper = document.createElement('div');
      wrapper.className = 'flex justify-end';

      const msgBubble = document.createElement('div');
      msgBubble.className = 'max-w-[85%] rounded-lg rounded-br-none bg-primary px-3 py-2 text-sm text-white';
      msgBubble.textContent = text;
      wrapper.appendChild(msgBubble);

      messagesArea.appendChild(wrapper);
      messagesArea.scrollTop = messagesArea.scrollHeight;
    }

    function handleAction(action) {
      const node = CONVERSATION_TREE[action];
      if (!node) {
        addBotMessage(FALLBACK_MESSAGE.text, FALLBACK_MESSAGE.quickReplies);
        return;
      }

      addBotMessage(node.text, node.quickReplies);

      if (node.navigate) {
        setTimeout(() => {
          window.location.href = node.navigate;
        }, 800);
      }
    }

    function matchKeywords(input) {
      const lower = input.toLowerCase().trim();
      for (const entry of KEYWORD_MAP) {
        for (const keyword of entry.keywords) {
          if (lower.includes(keyword)) {
            return entry.action;
          }
        }
      }
      return null;
    }

    function handleUserInput(text) {
      addUserMessage(text);

      const matchedAction = matchKeywords(text);
      if (matchedAction) {
        handleAction(matchedAction);
      } else {
        addBotMessage(FALLBACK_MESSAGE.text, FALLBACK_MESSAGE.quickReplies);
      }
    }

    bubble.addEventListener('click', toggleChat);
    closeBtn.addEventListener('click', toggleChat);

    inputForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const value = inputField.value.trim();
      if (!value) return;
      inputField.value = '';
      handleUserInput(value);
    });
  }

  initChatWidget();
  document.addEventListener('astro:after-swap', initChatWidget);
</script>
