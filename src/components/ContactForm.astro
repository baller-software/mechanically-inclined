---
interface Props {
  endpoint?: string;
}

const { endpoint = '' } = Astro.props;
---

<form id="contact-form" class="space-y-5" novalidate data-endpoint={endpoint}>
  <!-- Honeypot field — hidden from humans, catches bots -->
  <div class="absolute -left-[9999px]" aria-hidden="true">
    <label for="website">Website</label>
    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <!-- Name -->
  <div>
    <label for="name" class="block text-sm font-medium text-[var(--color-text-primary)]">
      Name <span class="text-[var(--color-error)]" aria-hidden="true">*</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      autocomplete="name"
      class="mt-1 block w-full rounded-md border border-[var(--color-border)] bg-transparent px-3 py-2 text-[var(--color-text-primary)] placeholder:text-[var(--color-text-disabled)] transition-colors duration-[var(--duration-fast)] focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      style="min-height: 44px;"
      placeholder="Your name"
    />
    <p class="mt-1 hidden text-sm text-[var(--color-error)]" id="name-error" role="alert"></p>
  </div>

  <!-- Email -->
  <div>
    <label for="email" class="block text-sm font-medium text-[var(--color-text-primary)]">
      Email <span class="text-[var(--color-error)]" aria-hidden="true">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      class="mt-1 block w-full rounded-md border border-[var(--color-border)] bg-transparent px-3 py-2 text-[var(--color-text-primary)] placeholder:text-[var(--color-text-disabled)] transition-colors duration-[var(--duration-fast)] focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      style="min-height: 44px;"
      placeholder="you@example.com"
    />
    <p class="mt-1 hidden text-sm text-[var(--color-error)]" id="email-error" role="alert"></p>
  </div>

  <!-- Phone (optional) -->
  <div>
    <label for="phone" class="block text-sm font-medium text-[var(--color-text-primary)]">
      Phone <span class="text-sm font-normal text-[var(--color-text-secondary)]">(optional)</span>
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      autocomplete="tel"
      class="mt-1 block w-full rounded-md border border-[var(--color-border)] bg-transparent px-3 py-2 text-[var(--color-text-primary)] placeholder:text-[var(--color-text-disabled)] transition-colors duration-[var(--duration-fast)] focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      style="min-height: 44px;"
      placeholder="(555) 123-4567"
    />
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-sm font-medium text-[var(--color-text-primary)]">
      Message <span class="text-[var(--color-error)]" aria-hidden="true">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="mt-1 block w-full rounded-md border border-[var(--color-border)] bg-transparent px-3 py-2 text-[var(--color-text-primary)] placeholder:text-[var(--color-text-disabled)] transition-colors duration-[var(--duration-fast)] focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      placeholder="Tell us about your project or question..."
    ></textarea>
    <p class="mt-1 hidden text-sm text-[var(--color-error)]" id="message-error" role="alert"></p>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    id="submit-btn"
    class="inline-flex w-full items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors duration-[var(--duration-fast)] hover:bg-primary-dark disabled:cursor-not-allowed disabled:opacity-50 sm:w-auto"
    style="min-height: 44px;"
  >
    <span id="submit-text">Send Message</span>
    <svg id="submit-spinner" class="ml-2 hidden h-4 w-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
  </button>
</form>

<!-- Success message (hidden by default) -->
<div id="form-success" class="hidden rounded-lg border border-green-200 bg-green-50 p-6 text-center dark:border-green-900 dark:bg-green-950" role="status">
  <svg class="mx-auto h-10 w-10 text-[var(--color-success)]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
  </svg>
  <h3 class="mt-3 text-lg font-semibold text-[var(--color-text-primary)]">Message Sent!</h3>
  <p class="mt-1 text-sm text-[var(--color-text-secondary)]">
    Thank you for reaching out. We'll get back to you as soon as possible.
  </p>
</div>

<!-- Error message (hidden by default) -->
<div id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 p-6 text-center dark:border-red-900 dark:bg-red-950" role="alert">
  <svg class="mx-auto h-10 w-10 text-[var(--color-error)]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
  </svg>
  <h3 class="mt-3 text-lg font-semibold text-[var(--color-text-primary)]">Something went wrong</h3>
  <p class="mt-1 text-sm text-[var(--color-text-secondary)]">
    Please try again, or contact us directly at <a href="tel:9728007000" class="text-primary hover:underline">(972) 800-7000</a>.
  </p>
</div>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;

    const endpoint = form.dataset.endpoint || '';
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitText = document.getElementById('submit-text')!;
    const submitSpinner = document.getElementById('submit-spinner')!;
    const successMsg = document.getElementById('form-success')!;
    const errorMsg = document.getElementById('form-error')!;

    function showError(fieldId: string, message: string) {
      const errorEl = document.getElementById(`${fieldId}-error`);
      const inputEl = document.getElementById(fieldId);
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.classList.remove('hidden');
      }
      inputEl?.classList.add('border-[var(--color-error)]');
    }

    function clearError(fieldId: string) {
      const errorEl = document.getElementById(`${fieldId}-error`);
      const inputEl = document.getElementById(fieldId);
      if (errorEl) {
        errorEl.textContent = '';
        errorEl.classList.add('hidden');
      }
      inputEl?.classList.remove('border-[var(--color-error)]');
    }

    function validateForm(): boolean {
      let valid = true;
      const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

      clearError('name');
      clearError('email');
      clearError('message');

      if (!name) {
        showError('name', 'Name is required.');
        valid = false;
      }

      if (!email) {
        showError('email', 'Email is required.');
        valid = false;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError('email', 'Please enter a valid email address.');
        valid = false;
      }

      if (!message) {
        showError('message', 'Message is required.');
        valid = false;
      }

      return valid;
    }

    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();

      if (!validateForm()) return;

      // Check honeypot
      const honeypot = (form.elements.namedItem('website') as HTMLInputElement).value;
      if (honeypot) {
        // Silently "succeed" for bots
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
        return;
      }

      // Disable submit
      submitBtn.disabled = true;
      submitText.textContent = 'Sending...';
      submitSpinner.classList.remove('hidden');

      const data = new FormData(form);
      // Remove honeypot from payload
      data.delete('website');

      try {
        if (!endpoint) {
          // Dev mode — log to console
          console.log('Form submission (no endpoint configured):', Object.fromEntries(data));
          form.classList.add('hidden');
          successMsg.classList.remove('hidden');
          return;
        }

        const res = await fetch(endpoint, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.classList.add('hidden');
          successMsg.classList.remove('hidden');
        } else {
          form.classList.add('hidden');
          errorMsg.classList.remove('hidden');
        }
      } catch {
        form.classList.add('hidden');
        errorMsg.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitText.textContent = 'Send Message';
        submitSpinner.classList.add('hidden');
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
